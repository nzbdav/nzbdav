{
  "name": "nzb-webdav",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "react-router build",
    "build:server": "tsc -p tsconfig.node.json --outDir dist-node",
    "dev": "cross-env NODE_ENV=development PORT=5173 tsx server.ts",
    "start": "node dist-node/server.js",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc -b"
  },
  "dependencies": {
    "@react-router/express": "~8.1.0",
    "@react-router/fs-routes": "~8.1.0",
    "@react-router/node": "~8.1.0",
    "compression": "^1.7.5",
    "express": "^5.2.0",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^3.0.5",
    "isbot": "^5.1.0",
    "material-symbols": "^0.45.7",
    "mime-types": "^3.0.2",
    "morgan": "^1.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "~8.1.0",
    "remix-auth": "^4.2.0",
    "remix-auth-form": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@react-router/dev": "~8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "http-proxy-middleware": {
      "http-proxy": "npm:http-proxy-node16@^1.0.6"
    }
  }
}
