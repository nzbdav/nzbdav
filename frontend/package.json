{
  "name": "nzb-webdav",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "react-router build",
    "build:server": "tsc -p tsconfig.node.json --outDir dist-node",
    "predev": "bash ../scripts/sync-dev-env.sh",
    "dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server.ts",
    "start": "node dist-node/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "react-router typegen && tsc -b"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-router/express": "~8.1.0",
    "@react-router/fs-routes": "~8.1.0",
    "@react-router/node": "~8.1.0",
    "compression": "^1.7.5",
    "express": "^5.2.0",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^4.1.1",
    "isbot": "^5.1.0",
    "material-symbols": "^0.45.7",
    "mime-types": "^3.0.2",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "~8.1.0",
    "remix-auth": "^4.2.0",
    "remix-auth-form": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "~8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
